# Test Professional Investor

> Include: ../catala/professional_investor.catala_en

## Test Cases

```catala-metadata
declaration scope Investor_Test_Suite:
  output all_passed content boolean
  output input_CreditInst_Profile content InvestorProfile
  output input_LargeUndertaking_Profile content InvestorProfile
  output input_RAIF_Profile content RAIFInvestorProfile
```

```catala
scope Investor_Test_Suite:
  # Case 1: Per Se Professional (Credit Institution)
  definition input_CreditInst_Profile equals InvestorProfile {
      -- per_se_category: CreditInstitution
      -- large_undertaking_data: LargeUndertakingTest {
           -- balance_sheet_total: $0
           -- net_turnover: $0
           -- own_funds: $0
         }
      -- has_requested_professional_treatment: false
      -- firm_has_assessed_expertise: false
  }

  # Case 3: Large Undertaking (Balance Sheet + Turnover)
  definition input_LargeUndertaking_Profile equals InvestorProfile {
      -- per_se_category: NotPerSeProfessional
      -- large_undertaking_data: LargeUndertakingTest {
           -- balance_sheet_total: $25,000,000
           -- net_turnover: $50,000,000
           -- own_funds: $0
         }
      -- has_requested_professional_treatment: false
      -- firm_has_assessed_expertise: false
  }

  # Case 4: RAIF Well-Informed (125k + Assessment)
  definition input_RAIF_Profile equals RAIFInvestorProfile {
      -- mifid_profile: InvestorProfile {
           -- per_se_category: NotPerSeProfessional
           -- large_undertaking_data: LargeUndertakingTest {
                -- balance_sheet_total: $0
                -- net_turnover: $0
                -- own_funds: $0
              }
           -- has_requested_professional_treatment: false
           -- firm_has_assessed_expertise: false
         }
      -- investing_minimum_125k: true
      -- has_institutional_assessment: true
      -- has_written_confirmation_of_expertise: false
      -- is_director_or_conductor: false
  }

  # Test assertions using Catala scope instantiation
  definition all_passed equals
    let result_credit_inst equals output of ProfessionalInvestorStatus with
      { -- investor: input_CreditInst_Profile }
    in
    let result_large_undertaking equals output of ProfessionalInvestorStatus with
      { -- investor: input_LargeUndertaking_Profile }
    in
    let result_raif equals output of WellInformedInvestorStatus with
      { -- investor: input_RAIF_Profile }
    in
    # Credit institution is per se professional
    result_credit_inst.is_professional = true
    # Large undertaking meets 2/3 criteria (balance sheet + turnover)
    and result_large_undertaking.is_professional = true
    # RAIF investor with 125k + assessment is well-informed
    and result_raif.is_well_informed = true
```
